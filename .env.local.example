# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from console.neon.tech → Project → Connect → Connection string
DATABASE_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:PASSWORD@ep-xxxx.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="PulseCRM"
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# ─── SMTP Email ───────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
EMAIL_FROM="PulseCRM <noreply@your-domain.com>"

# ─── AI (OpenRouter) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY="sk-or-v1-..."
LLM_API_URL="https://openrouter.ai/api/v1/chat/completions"
LLM_MODEL="openai/gpt-4o-mini"
TAILOR_LLM_MODEL="openai/gpt-4o-mini"
